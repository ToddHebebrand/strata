{
  "name": "@strata-code/lab",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "echo '[@strata-code/lab] NON-AUTHORITATIVE sandbox. Run: pnpm --filter @strata-code/lab test:lab'",
    "test:lab": "vitest run",
    "lab": "node dist/run.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.118",
    "@strata-code/agent": "workspace:*",
    "@strata-code/ingest": "workspace:*",
    "@strata-code/render": "workspace:*",
    "@strata-code/store": "workspace:*",
    "@strata-code/verify": "workspace:*",
    "typescript": "^5.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "vitest": "^3.2.4"
  }
}
