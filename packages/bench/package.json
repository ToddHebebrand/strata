{
  "name": "@strata-code/bench",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "bench": "node dist/runner.js",
    "bench:t03": "node dist/runner.js --tasks=T03",
    "dogfood:l1": "node dist/dogfoodL1Cli.js",
    "dogfood:l3": "node dist/dogfoodL3Cli.js",
    "dogfood:extract": "node dist/dogfoodExtractCli.js",
    "dogfood:move": "node dist/dogfoodMoveCli.js",
    "dogfood:inline": "node dist/dogfoodInlineCli.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.118",
    "@strata-code/agent": "workspace:*",
    "@strata-code/ingest": "workspace:*",
    "@strata-code/render": "workspace:*",
    "@strata-code/store": "workspace:*",
    "@strata-code/verify": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
