{
  "name": "@strata/ingest",
  "version": "0.1.0",
  "description": "TypeScript source to Strata node graph, via the TypeScript Compiler API",
  "keywords": [
    "ai-agents",
    "code-graph",
    "structural-refactoring",
    "typescript",
    "refactoring",
    "developer-tools",
    "code-substrate"
  ],
  "license": "MIT",
  "author": "Todd Hebebrand",
  "homepage": "https://github.com/ToddHebebrand/strata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ToddHebebrand/strata.git",
    "directory": "packages/ingest"
  },
  "bugs": {
    "url": "https://github.com/ToddHebebrand/strata/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "export:kernel-snapshot": "node dist/exportKernelSnapshotCli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@strata/store": "workspace:*",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "vitest": "^3.2.4"
  }
}
