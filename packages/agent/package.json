{
  "name": "@strata/agent",
  "version": "0.1.0",
  "description": "Claude Agent SDK agent that works a codebase through Strata's structural tools only — no filesystem tools",
  "keywords": [
    "ai-agents",
    "code-graph",
    "structural-refactoring",
    "typescript",
    "refactoring",
    "developer-tools",
    "code-substrate"
  ],
  "license": "MIT",
  "author": "Todd Hebebrand",
  "homepage": "https://github.com/ToddHebebrand/strata#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ToddHebebrand/strata.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/ToddHebebrand/strata/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "record:t03-fixture": "node scripts/record-t03-fixture.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.118",
    "@strata/ingest": "workspace:*",
    "@strata/store": "workspace:*",
    "@strata/verify": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
